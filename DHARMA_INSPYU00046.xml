      <body>
			<div type="edition" xml:lang="pli-Latn">
				<div type="textpart" n="First leaf (Or5340A)">
					<!-- Or5340A before Or5340B unless B is meant to be read before A -->
					<ab>
						<g>⎨||⋮||⎬</g>
						<lb n="1"/>
						<g type="ddanda">.</g>
						ye
						dhammā
						hetupabhavā
						<space type="horizontal" quantity="1" unit="chars"/>
						tesaṁ
						hetu<supplied reason="omitted">ṁ</supplied>
						tathāgato
						<space type="horizontal" quantity="1" unit="chars"/>
						°āha
						tesañ
						ca
						yo
						nirodho
						<space type="horizontal" quantity="1" unit="chars"/>
						°evaṁvādi
						mahāsamano
						ti
						<g type="ddanda">.</g>
						cattāro
						°iddhipādā
						<lb n="2"/>
						cattāro
						sammappadhānā
						<space type="horizontal" quantity="1" unit="chars"/>
						cattāro
						satipaṭṭhānā
						<space type="horizontal" quantity="1" unit="chars"/>
						cattāri
						°ariyasaccāni
						<space type="horizontal" quantity="1" unit="chars"/>
						catuves<supplied reason="omitted">ā</supplied>rajjāni 
						<space type="horizontal" quantity="1" unit="chars"/>
						pañcindriyāni
						<space type="horizontal" quantity="1" unit="chars"/>
						pañcacakkhūni
						<space type="horizontal" quantity="1" unit="chars"/>
						cha<lb n="3" break="no"/>°asaddhāraṇ<unclear>ā</unclear>ni 
						<space type="horizontal" quantity="1" unit="chars"/>
						sattabojjhaṅgā
						<space type="horizontal" quantity="1" unit="chars"/>
						°ariyo
						°aṭṭhiṅgiko
						maggo
						<space type="horizontal" quantity="1" unit="chars"/>
						navalokuttarā
						dhammā
						<space type="horizontal" quantity="1" unit="chars"/>
						dasabal<supplied reason="omitted">ā</supplied>ni
						<space type="horizontal" quantity="1" unit="chars"/>
						cundasa
						buddhaññāni
						°aṭṭhārasabuddhadhammāni
					</ab>
				</div>
				<div type="textpart" n="Second leaf (Or5340B)">
					<ab>
						<lb n="1"/>
						<g type="ddanda">.</g>
						ye
						dhammā
						hetupabhavā
						<space type="horizontal" quantity="1" unit="chars"/>
						tesa<supplied reason="omitted">ṁ</supplied>
						hetu<supplied reason="omitted">ṁ</supplied>
						tathāgato
						°āha
						<space type="horizontal" quantity="1" unit="chars"/>
						tesañ
						ca
						yo
						nirodho
						<space type="horizontal" quantity="1" unit="chars"/>
						°evaṁvādi
						mahāsama<unclear>n</unclear>o
						ti
						<space type="horizontal" quantity="1" unit="chars"/>
						°iti
						pi
						so
						bhagavā
						°arahaṁ
						<lb n="2"/>
						sammāsaṁbuddho
						<space type="horizontal" quantity="1" unit="chars"/>
						vijjācaraṇasappanno
						<space type="horizontal" quantity="1" unit="chars"/>
						sugato
						lokavidu
						<space type="horizontal" quantity="1" unit="chars"/>
						°anuttaro
						purisadammasārathī
						<space type="horizontal" quantity="1" unit="chars"/>
						satthā
						devamanussānaṁ
						<space type="horizontal" quantity="1" unit="chars"/>
						buddho
						bhagavā
						ti
						<lb n="3"/>
						svākhyāto
						bhagavatā
						dhammo
						<space type="horizontal" quantity="1" unit="chars"/>
						sandiṭṭhiko
						<space type="horizontal" quantity="1" unit="chars"/>
						°akāl<supplied reason="omitted">i</supplied>ko
						<space type="horizontal" quantity="1" unit="chars"/>
						°ehipassiko
						<space type="horizontal" quantity="1" unit="chars"/>
						<supplied reason="lost">°o</supplied>paṇāyiko
						<space type="horizontal" quantity="1" unit="chars"/>
						paccattaṁ
						veditavvo
						<space type="horizontal" quantity="1" unit="chars"/>
						viññūhī
						ti
						<g>⎨||⋮||⎬</g>
					</ab>
				</div>
			</div>
			<div type="apparatus">
				<listApp><!-- Finot 1912 readings still need to be collated -->
					<app loc="1.margin">
						<lem><g>⎨||⋮||⎬</g></lem>
						<rdg resp="Tun Nyein"><g type="ddanda">.</g></rdg>
						<note>The opening mark stands in the margin; the same sign is repeated at
							the end of leaf 2. It is a simpler version of the one seen at the end of PYU <ref target="DHARMA_INSPYU00044">44</ref>.</note>
					</app>
					<app loc="1.1">
						<lem>tesañ ca</lem>
						<note>There is a rightward curl at the top of the vertical element in <seg type="graphemic">ñ</seg>, that could possibly be interpreted as <seg type="graphemic">-ā</seg>, but we assume it is a somewhat overdone serif.</note>
					</app>
					<app loc="1.1">
						<lem>°evaṁvādi mahāsamano</lem>
						<note>The expected form would be <foreign xml:lang="pli-Latn">°evaṁvādī mahāsamaṇo</foreign>. Same irregularities in leaf 2.</note>
					</app>
					<app loc="1.2">
						<lem>satipaṭṭhānā</lem>
						<rdg resp="Tun Nyein">satipaṭṭhāuā</rdg>
						<note>(misprint)</note>
					</app>
					<app loc="1.2">
						<lem>°ariyasaccāni</lem>
						<rdg resp="Tun Nyein">°ariyasacohāni</rdg>
						<note>(misprint)</note>
					</app>
					<app loc="1.3">
						<lem>°asaddhāraṇ<unclear>ā</unclear>ni</lem>
						<note>Tun Nyein corrects <foreign xml:lang="pli-Latn">°asādhāraṇāni </foreign> in note.</note>
					</app>
					<app loc="1.3">
						<lem>°aṭṭhiṅgiko</lem>
						<note>Tun Nyein corrects <foreign xml:lang="pli-Latn">°aṭṭhaṅgiko</foreign> in note.</note>
					</app>
					<app loc="1.3">
						<lem>dasabal<supplied reason="omitted">ā</supplied>ni</lem>
						<note>Tun Nyein silently corrects <foreign xml:lang="pli-Latn">dasabalāni</foreign>.</note>
					</app>
					<app loc="1.3">
						<lem>cundasa</lem>
						<note>Tun Nyein silently corrects <foreign xml:lang="pli-Latn">cuddasa</foreign>.</note>
					</app>
					<app loc="1.3">
						<lem>buddhaññāni</lem>
						<rdg resp="Tun Nyein">buddhakoni</rdg>
						<note>correcting <foreign xml:lang="pli-Latn">buddhayonī</foreign> in note; emend <foreign xml:lang="pli-Latn">buddhañāṇāni</foreign>.</note>
					</app>
					<app loc="2.1">
						<lem><g type="ddanda">.</g></lem>
						<note>The two bars are connected by a small cross-bar.</note>
					</app>
					<app loc="2.1">
						<lem>°evaṁvādi mahāsamano</lem>
						<note>The expected form would be <foreign xml:lang="pli-Latn">°evaṁvādī mahāsamaṇo</foreign>. Same irregularities in leaf 1.</note>
					</app>
					<app loc="2.2">
						<lem>-sappanno</lem>
						<note>Tun Nyein corrects <foreign xml:lang="pli-Latn">-sampanno</foreign> in note.</note>
					</app>
					<app loc="2.2">
						<lem>-sārathī</lem>
						<rdg resp="Tun Nyein">-sārathi</rdg>
					</app>
					<app loc="2.3">
						<lem>°akāl<supplied reason="omitted">i</supplied>ko</lem>
						<rdg resp="Tun Nyein">°akāliko</rdg>
						<note>Silent correction.</note>
					</app>
					<app loc="2.3">
						<lem><supplied reason="lost">°o</supplied>paṇāyiko</lem>
						<note>Tun Nyein corrects <foreign xml:lang="pli-Brah">°opanayiko</foreign> in note. Editions of the canon show either <foreign>°opaneyyika</foreign> or <foreign xml:lang="pli-Brah">°opanāyiko</foreign>.</note>
					</app>
					<app loc="2.3">
						<lem><g>⎨||⋮||⎬</g></lem>
						<rdg resp="Tun Nyein">||</rdg>
						<note>The closing sign here corresponds to the opening sign of leaf 1, and clearly shows the two leaves form one whole.</note>
					</app>
				</listApp>
			</div>
			<div type="translation" xml:lang="eng">
				<p><!--english translation here--></p>
			</div>
			<div type="commentary">
				<p><!-- commentary --></p>
